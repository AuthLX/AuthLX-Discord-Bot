# --- DISCORD CREDENTIALS ---
# The bot user token from the Discord Developer Portal (Bot tab)
DISCORD_TOKEN=your_bot_token_here

# The application Client ID from the Discord Developer Portal (General Information tab)
DISCORD_CLIENT_ID=your_client_id_here

# Optional: Specific Discord Server/Guild ID to register slash commands instantly (highly recommended for local testing)
DISCORD_GUILD_ID=

# --- AUTHLX BACKEND ENDPOINT ---
# URL pointing to the AuthLX developer backend API
AUTH_API_URL=https://authlx.com/api/v1/dev
